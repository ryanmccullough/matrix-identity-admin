# Secrets — never commit
# Only the root .env/.envrc are excluded; e2e/.env contains test-only values and is tracked.
/.env
/.envrc

# Rust build artifacts
/target/

# Runtime data (SQLite database, audit logs)
/data/

# Node (not part of the Rust project)
node_modules/
package.json
package-lock.json

# Flox runtime state and local npm installs (env config is kept)
.flox/run/
.flox/cache/
.flox/lib/
.flox/log/
.flox/npm-global/

# CodeQL local analysis artifacts (results live in GitHub Security tab, not the repo)
codeql-db/
*.sarif

# E2E provisioned tokens (generated by e2e/provision-admin-token.sh)
e2e/shared/

# Git worktrees
.worktrees/

# Editor / OS
.DS_Store
.idea/
.vscode/
*.swp
