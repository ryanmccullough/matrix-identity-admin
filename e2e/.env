# E2E environment variables — run the admin app locally against Docker dependencies.
#
# Usage:
#   docker compose -f e2e/docker-compose.yml up -d   # start dependencies
#   cp e2e/.env .env && flox activate -- cargo run    # run the app
#
# Credentials are intentional test values, not real secrets.

APP_BIND_ADDR=127.0.0.1:3000
APP_BASE_URL=http://localhost:3000
APP_SESSION_SECRET=e2e-session-secret-00000000000000000000000000000000
APP_REQUIRED_ADMIN_ROLE=matrix-admin
HOMESERVER_DOMAIN=e2e.test

# Keycloak OIDC — admin app login
# Keycloak runs on localhost:8081; browser redirects land here too.
OIDC_ISSUER_URL=http://localhost:8081/realms/test
OIDC_CLIENT_ID=matrix-admin-ui
OIDC_CLIENT_SECRET=admin-ui-secret
OIDC_REDIRECT_URL=http://localhost:3000/auth/callback

# Keycloak admin API — user search, create, delete
KEYCLOAK_BASE_URL=http://localhost:8081
KEYCLOAK_REALM=test
KEYCLOAK_ADMIN_CLIENT_ID=matrix-admin-service
KEYCLOAK_ADMIN_CLIENT_SECRET=admin-service-secret

# MAS admin API — session management, user deactivation/reactivation
MAS_BASE_URL=http://localhost:8082
MAS_ADMIN_CLIENT_ID=01KK519CRQY52VBDS3QQF6X7BN
MAS_ADMIN_CLIENT_SECRET=admin-oauth-secret

# SQLite audit log (separate from production db)
DATABASE_URL=sqlite://data/e2e-app.db

# Bot invite API — use this as the Bearer token when testing POST /api/v1/invites
BOT_API_SECRET=e2e-bot-secret

# Verbose logging for e2e debugging
RUST_LOG=debug

# Synapse admin API — user management, room operations
# In matrix_authentication_service mode, there is no static admin_token.
# The token is provisioned via mas-cli and written to e2e/shared/synapse-admin-token.
# SYNAPSE_ADMIN_TOKEN is read from that file by the test runner at startup.
SYNAPSE_BASE_URL=http://localhost:8008
SYNAPSE_ADMIN_USER=@testadmin:e2e.test
SYNAPSE_ADMIN_PASSWORD=unused-mas-mode

# Reconciliation — enable kick for testing
RECONCILE_REMOVE_FROM_ROOMS=true
